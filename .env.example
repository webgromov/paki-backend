# PostgreSQL (used by docker-compose and by DATABASE_URL below)
POSTGRES_USER=paki
POSTGRES_PASSWORD=paki
POSTGRES_DB=paki_support

# Prisma connects to Postgres exposed on localhost by docker-compose
DATABASE_URL="postgresql://paki:paki@localhost:5432/paki_support?schema=public"

# Backend
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Centrifugo
CENTRIFUGO_URL=http://localhost:8000
CENTRIFUGO_WS_URL=ws://localhost:8000/connection/websocket
CENTRIFUGO_API_KEY=dev_centrifugo_api_key
CENTRIFUGO_TOKEN_SECRET=dev_centrifugo_token_secret
