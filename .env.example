# PostgreSQL (used by docker-compose and by DATABASE_URL below)
POSTGRES_USER=paki
POSTGRES_PASSWORD=paki
POSTGRES_DB=paki_support

# Prisma connects to Postgres exposed on localhost by docker-compose
DATABASE_URL="postgresql://paki:paki@localhost:5432/paki_support?schema=public"

# Backend
PORT=3001
CORS_ORIGIN=http://localhost:3000
